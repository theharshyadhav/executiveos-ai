# ExecutiveOS AI — Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local — it's in .gitignore

# ── GEMINI (FREE) ────────────────────────────────────────────
# Get FREE at: https://aistudio.google.com/app/apikey
# Free tier: 15 req/min, 1M tokens/day — no credit card needed!
GEMINI_API_KEY=AIza_YOUR_FREE_KEY_HERE

# ── GITLAB (FREE) ────────────────────────────────────────────
# Get at: https://gitlab.com/-/profile/personal_access_tokens
# Scopes: api, read_repository, write_repository
GITLAB_TOKEN=glpat_YOUR_TOKEN_HERE
GITLAB_URL=https://gitlab.com
GITLAB_USERNAME=your_username

# ── MONGODB (FREE) ───────────────────────────────────────────
# Get FREE at: https://mongodb.com/atlas (M0 free cluster)
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/executiveos

# ── AUTH ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_32_char_string_here
NEXTAUTH_URL=http://localhost:3000

# ── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ExecutiveOS AI
